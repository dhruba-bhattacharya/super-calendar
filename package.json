{
    "main": "electron/main.cjs",
    "scripts": {
        "build": "node scripts/build.mjs",
        "dev": "npm run build && node scripts/serve.mjs",
        "dist:win": "npm run build && npx electron-builder --win nsis portable"
    },
    "devDependencies": {
        "electron": "latest",
        "electron-builder": "latest"
    },
    "build": {
        "appId": "com.calendar.desktop",
        "productName": "Calendar",
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "directories": {
            "output": "release"
        },
        "win": {
            "target": [
                "nsis",
                "portable"
            ],
            "icon": "public/icon.svg"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
